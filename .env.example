# Telegram Bot для приёма заявок с лендинга.
# Серверные переменные — НИКОГДА не VITE_*, иначе попадут в публичный бандл.
# Доступны только внутри Vercel Function (api/booking.js).

# Создать бота: @BotFather → /newbot → скопировать токен
TG_BOT_TOKEN=

# chat_id владельца барбершопа, куда падают заявки
# Узнать: @userinfobot → /start
TG_CHAT_ID=
