# Серверные переменные — НИКОГДА не VITE_*, иначе попадут в публичный бандл.
# Доступны только внутри Vercel Functions (api/booking.js, api/bot.ts).

# --- Telegram ---
# Создать бота: @BotFather → /newbot → скопировать токен
TG_BOT_TOKEN=

# chat_id владельца барбершопа, куда падают заявки (с формы и из бота)
# Узнать: @userinfobot → /start
TG_CHAT_ID=

# Секрет webhook: сверяется с заголовком Telegram, отсекает чужие POST на /api/bot.
# Сгенерировать: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Тот же секрет уходит в setWebhook (scripts/set-webhook.mjs).
TG_WEBHOOK_SECRET=

# --- Upstash Redis (сессии бота) ---
# console.upstash.com → Create Database → Redis → блок REST API
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
